{
  "name": "mini-car-catalog-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --ignore-path ../.prettierignore --write .",
    "format:check": "prettier --ignore-path ../.prettierignore --check .",
    "start": "node dist/server.js",
    "migrate:photos:r2": "npm run build && node dist/scripts/migratePhotosToR2.js",
    "optimize:photos:r2": "npm run build && node dist/scripts/optimizeExistingR2Photos.js",
    "test": "jest --config jest.config.cjs --runInBand --watchman=false",
    "test:coverage": "jest --config jest.config.cjs --runInBand --watchman=false --coverage"
  },
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "mongoose": "^9.7.0",
    "multer": "^2.1.1",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}

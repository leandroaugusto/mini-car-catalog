{
  "name": "mini-car-catalog-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint .",
    "format": "prettier --ignore-path ../.prettierignore --write .",
    "format:check": "prettier --ignore-path ../.prettierignore --check .",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "test": "jest --config jest.config.cjs --runInBand --watchman=false",
    "test:coverage": "jest --config jest.config.cjs --runInBand --watchman=false --coverage",
    "test:watch": "jest --config jest.config.cjs --watch --watchman=false"
  },
  "license": "ISC",
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "formik": "^2.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16"
  }
}
